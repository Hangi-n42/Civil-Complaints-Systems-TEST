# 환경 변수 샘플
# .env 파일로 복사해서 사용하세요

# API 설정
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Ollama 설정 (온디바이스 LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT=120

# ChromaDB 설정 (벡터 저장소)
CHROMA_DB_PATH=./data/chroma_db

# 임베딩 모델
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda

# 성능 설정
MAX_WORKERS=4
REQUEST_TIMEOUT=60
BATCH_SIZE=32

# 검증 설정
MIN_CONFIDENCE_SCORE=0.5
MAX_RETRY_COUNT=3
